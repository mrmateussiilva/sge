# Variáveis de ambiente — copie este arquivo para .env e preencha com valores reais
# cp .env.example .env

# Porta interna do Gunicorn (padrão: 8000)
PORT=8000

# Chave secreta do Django — gere uma nova com:
# python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=troque-por-uma-chave-de-50-ou-mais-caracteres-aleatorios

# Superusuário criado automaticamente no primeiro boot
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=senha-forte-aqui-minimo-12-chars
DJANGO_SUPERUSER_EMAIL=seu@email.com

# Produção: False | Desenvolvimento: True
DJANGO_DEBUG=False

# Hosts permitidos (separados por vírgula, sem espaços)
DJANGO_ALLOWED_HOSTS=sge.finderbit.com.br

# Domínios confiáveis para validação CSRF (com protocolo https://)
CSRF_TRUSTED_ORIGINS=https://sge.finderbit.com.br
